# Supabase — https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter — https://openrouter.ai/keys (used for chat — free Gemma model)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# OpenAI — https://platform.openai.com/api-keys (used for vision scan, whisper, embeddings only)
OPENAI_API_KEY=sk-your-openai-key

# Qdrant Cloud — https://cloud.qdrant.io → Cluster → API Keys
QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your-elevenlabs-key

# ElevenLabs Voice ID — set after voice clone audio prep is done
ELEVENLABS_VOICE_ID=ADD_AFTER_VOICE_CLONE

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=ADD_AFTER_GENERATING
VAPID_PRIVATE_KEY=ADD_AFTER_GENERATING
